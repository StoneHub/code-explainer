{
	"name": "code-explainer",
	"displayName": "Code Explainer",
	"description": "Highlights code ranges in VS Code for interactive code walkthroughs.",
	"version": "0.1.0",
	"publisher": "srujangurram",
	"icon": "../assets/icon.png",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": ["Other"],
	"activationEvents": ["*"],
	"main": "./out/extension.js",
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"package": "vsce package --no-dependencies"
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@types/vscode": "^1.85.0",
		"typescript": "^5.3.0"
	}
}
